<mujoco model="Tesollo DG5F scene">
  <include file="dg5f_right.xml"/>

  <!-- <include file="iiwa14_prefix.xml" prefix="r1" pos="0.0 0.0 0.0"/> -->

  <statistic center="0.2 0 0.2" extent="1.0"/>

   <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20" offwidth="1920" offheight="1080"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.95 0.95 0.95" rgb2="0.9 0.9 0.9" width="512" height="3072"/>
    <texture name="grid" type="2d" builtin="checker" rgb1=".2 .3 .4" rgb2=".1 0.15 0.2" width="512" height="512"
      mark="cross" markrgb=".8 .8 .8"/>
    <material name="grid" texture="grid" texrepeat="1 1" texuniform="true" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" directional="true"/>
    <geom name="floor" size="1 1 0.01" type="plane" material="grid" contype="1" conaffinity="1"/>

    <camera name="cam_front" pos="0 -1.1 0.37" quat="0.819134 0.573602 1.13747e-05 6.4521e-05" fovy="45"/>
    <camera name="cam_side" pos="0.45 -0.83 0.40" quat="0.729512 0.472006 0.297701 0.395471" fovy="45"/>
  

    <!-- Объект захвата формы cube, добавленный для эксперимента ВКР. -->
    <body name="grasp_object" pos="-0.025 0.0 0.115">
      <freejoint name="grasp_object_joint"/>
      <geom name="grasp_object_geom"
            type="box"
            size="0.025 0.025 0.025"
            mass="0.05"
            rgba="0.9 0.25 0.15 1"
            friction="1.2 0.02 0.001"
            contype="1"
            conaffinity="1"/>
    </body>

  </worldbody>
</mujoco>
